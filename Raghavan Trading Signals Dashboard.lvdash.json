    {
      "name": "fb7b69cc",
      "displayName": "kpis",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT symbol)                                              AS stocks_tracked,\n",
        "  COUNT(DISTINCT CASE WHEN rsi_zone    = 'Oversold'       THEN symbol END) AS oversold,\n",
        "  COUNT(DISTINCT CASE WHEN rsi_zone    = 'Overbought'     THEN symbol END) AS overbought,\n",
        "  COUNT(DISTINCT CASE WHEN volume_flag = 'Unusual Volume' THEN symbol END) AS unusual_volume\n",
        "FROM raghavan_trading_signals.gold.v_daily_signals;"
      ]
    }
  ],
